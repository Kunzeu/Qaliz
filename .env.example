DISCORD_TOKEN=tu_token_aqui

# Auto-upload de logs arcdps
LOG_AUTOUPLOAD_ENABLED=true

# Una persona
# ARCDPS_LOG_DIR=C:\Users\Kunzeu\Documents\Guild Wars 2\addons\arcdps\arcdps.cbtlogs

# Varias personas (separadas por ;)
ARCDPS_LOG_DIRS=C:\Users\Kunzeu\Documents\Guild Wars 2\addons\arcdps\arcdps.cbtlogs;C:\Users\OtroJugador\Documents\Guild Wars 2\addons\arcdps\arcdps.cbtlogs

# En Linux VPS, una carpeta por jugador sincronizada al servidor:
# ARCDPS_LOG_DIRS=/data/arcdps/kunzeu;/data/arcdps/jugador2;/data/arcdps/jugador3

# Opcional
# LOG_AUTOUPLOAD_POLL_SECONDS=8
# LOG_AUTOUPLOAD_ONLY_SUCCESS=true
# LOG_AUTOUPLOAD_MIN_PLAYERS=4
